{
  "expo": {
    "name": "BusTrack Passenger",
    "slug": "bustrack-passenger",
    "version": "1.0.0",
    "orientation": "portrait",
    "newArchEnabled": false,
    "userInterfaceStyle": "automatic",
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1E40AF"
      },
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY"
        }
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE"
      ],
      "package": "com.anonymous.bustrackpassenger"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "BusTrack needs location to find nearby buses."
        }
      ],
      [
        "react-native-maps",
        {
          "googleMapsApiKey": "AIzaSyBnbnbiedLS5eVA5nL9SG6s5C4VnezRwVI"
        }
      ]
    ]
  }
}